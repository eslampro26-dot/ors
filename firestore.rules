rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Trips & Packages: Publicly readable from browser, writes via server API
    match /trips/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /packages/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // 2. Reviews: Publicly readable, writes allowed (rate-limited via server)
    match /reviews/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // 3. Settings & Social Media: Publicly readable, writes allowed via API
    match /settings/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /social_media/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // 4. Agents, Bookings, Promo Codes: server-side API endpoints only
    match /bookings/{document=**} {
      allow read, write: if true;
    }
    match /agents/{document=**} {
      allow read, write: if true;
    }
    match /promo_codes/{document=**} {
      allow read, write: if true;
    }
    
    // 5. Meta initialization document
    match /_meta/{document=**} {
      allow read, write: if true;
    }
  }
}
